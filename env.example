# Root Docker Environment Configuration
# This file is for Docker Compose only.
# For local development, use backend/.env.example and frontend/.env.example

# Docker Environment
NODE_ENV=production

# Infrastructure
DATABASE_URL=postgres://claude_user:claude_password@postgres:5432/claude_projects
REDIS_URL=redis://redis:6379

# JWT Secrets (Change these in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# AI API Keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# CORS
CORS_ORIGIN=http://localhost:3000

# Swagger
ENABLE_SWAGGER=false

# File Upload
MAX_FILE_SIZE=52428800

# Logging
LOG_LEVEL=info

# Admin Configuration
ADMIN_EMAIL=admin@example.com
DEFAULT_TOKEN_LIMIT_GLOBAL=1000000
DEFAULT_TOKEN_LIMIT_MONTHLY=100000
